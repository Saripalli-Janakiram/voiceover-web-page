{
  "manifest_version": 3,
  "name": "VoiceOver Web Page",
  "version": "2.0",
  "description": "Reads selected text or full webpages aloud using built-in browser voices.",
  "permissions": ["activeTab", "scripting"],
  "host_permissions": ["<all_urls>"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "128": "icon128.png"
    }
  },
  "icons": {
    "128": "icon128.png"
  }
}
