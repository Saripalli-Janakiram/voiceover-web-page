{
  "manifest_version": 3,
  "name": "VoiceOver Web Page",
  "version": "1.0",
  "description": "Free full-page text-to-speech reader using built-in browser voices.",
  "permissions": ["scripting", "activeTab"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "128": "icon128.png"
    }
  },
  "icons": {
    "128": "icon128.png"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
